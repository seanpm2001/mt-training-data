			</tuv>
			<tuv xml:lang="nhe">
				<seg>Xi techpalehui ti temoze sekinoj tech palehuiz hua tlatoli.</seg>
			</tuv>
		</tu>
		<tu tuid="common-voice:web/locales/en/messages.ftl:email-opt-in-info" srclang="en-US">
			<tuv xml:lang="en-US">
				<seg>I'd like to receive emails such as goal reminders, my progress updates and newsletters about Common Voice.</seg>
			</tuv>
			<tuv xml:lang="nhe">
				<seg>Ninekiskia xinechtitlanilij emails ipan tlen tinekin tichihuase, then tichiheia ,tlen ticonchiheia huan huan yankhuik tlatoli then Common Voice.</seg>
			</tuv>
		</tu>
