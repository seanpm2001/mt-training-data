		<tu tuid="common-voice:web/locales/en/messages.ftl:share-text" srclang="en-US">
			<tuv xml:lang="en-US">
				<seg>Help teach machines how real people speak, donate your voice at { $link }</seg>
			</tuv>
			<tuv xml:lang="nhe">
				<seg>Xitechpalehui timachtize tepozme kenikatza ce tlakatl o cihuatl kamati, xitechmalehui ka mo tlatolij { $link }</seg>
